                "kart_detay_gorsel": null,
                "kart_detay_aciklama": "<div class=\"floating-card-wrapper\" style=\"top: -21.2506%; left: 10.3162%;\" data-depth=\"0.6\">                        <div class=\"about-card card-vision\">                            <div class=\"vision-content\">                                <h4 style=\"color: #f39c12;\">Vizyonumuz<\/h4>                                <p>Teknoloji, tasarım trendleri ve küresel standartlarla sürekli gelişerek yapısal peyzaj ve kent ekipmanları çözümlerinde lider bir marka olmak.<\/p>                            <\/div>                        <\/div>                    <\/div>",
