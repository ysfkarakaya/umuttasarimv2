RewriteEngine On
RewriteBase /

# Redirect language-prefixed sitemap, robots, and llm files to root
RewriteRule ^(tr|en|ru)/(sitemap\.xml|robots\.txt|llm\.txt)$ /$2 [R=301,L]

# Redirect language-prefixed projeler requests to clean /projeler/
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^(tr|en|ru)/projeler(/(.*))?$ /projeler/$3 [R=301,L]

# Sitemap rewrite
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Force HTTPS and non-WWW on Production
RewriteCond %{HTTP_HOST} ^(www\.)?umuttasarim\.com$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://umuttasarim.com%{REQUEST_URI} [R=301,L]

# 1. Redirect homepage requests with query lang parameter to clean root /en/
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} (?:^|&)lang=(tr|en|ru)(?:&|$) [NC]
RewriteCond %{REQUEST_URI} ^/(?:(?:tr|en|ru)/)?(?:index\.php)?$ [NC]
RewriteRule ^ /%1/? [R=301,L]

# 2. Redirect page requests with query lang parameter and existing lang prefix to clean /en/hakkimizda
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} (?:^|&)lang=(tr|en|ru)(?:&|$) [NC]
RewriteRule ^(?:tr|en|ru)/(.*)$ /%1/$1? [R=301,L]

# 3. Redirect page requests with query lang parameter and no lang prefix to clean /en/hakkimizda
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} (?:^|&)lang=(tr|en|ru)(?:&|$) [NC]
RewriteCond %{REQUEST_URI} !^/(tr|en|ru)/ [NC]
RewriteCond %{REQUEST_URI} !^/(assets|upload|data|inc|projeler)/ [NC]
RewriteRule ^(.*)$ /%1/$1? [R=301,L]

# Redirect direct external requests without language prefix to /tr/
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_URI} !^/(tr|en|ru)/ [NC]
RewriteCond %{REQUEST_URI} !^/(assets|upload|data|inc|projeler)/ [NC]
RewriteCond %{REQUEST_URI} !^/(sitemap\.xml|robots\.txt|llm\.txt)$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f [OR]
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteRule ^(.*)$ /tr/$1 [R=301,L]

# Redirect /tr, /en, /ru to /tr/, /en/, /ru/
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^(tr|en|ru)$ /$1/ [R=301,L]

# Force trailing slash on directories (skip for languages)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !^/(tr|en|ru)/?$
RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

# If the request matches an existing file or directory, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Map .php file calls with language prefix: /tr/index.php -> index.php?lang=tr
RewriteCond %{DOCUMENT_ROOT}/$2 -f
RewriteRule ^(tr|en|ru)/([^/]+\.php)$ $2?lang=$1 [L,QSA]

# Homepage rule
RewriteRule ^(tr|en|ru)/$ index.php?lang=$1 [L,QSA]

# Blog rules
RewriteRule ^(tr|en|ru)/blog$ blog.php?lang=$1 [L,QSA]
RewriteRule ^(tr|en|ru)/blog/([a-zA-Z0-9_-]+)$ blog-detay.php?name=$2&lang=$1 [L,QSA]

# SEF URL mapping for Products/Categories/Applications
RewriteRule ^(tr|en|ru)/urunler/([a-zA-Z0-9_-]+)$ urunler.php?slug=$2&lang=$1 [QSA,L]
RewriteRule ^(tr|en|ru)/urun/([a-zA-Z0-9_-]+)$ urun-detay.php?sef_url=$2&lang=$1 [QSA,L]
RewriteRule ^(tr|en|ru)/uygulamalar/([a-zA-Z0-9_-]+)$ uygulamalar.php?slug=$2&lang=$1 [QSA,L]

# Special cases for new pages that might use sayfa-detay.php
RewriteRule ^(tr|en|ru)/(yonetim-sistemleri|kariyer)$ sayfa-detay.php?slug=$2&lang=$1 [L,QSA]

# General page mapping: /tr/hakkimizda -> hakkimizda.php?lang=tr
RewriteCond %{DOCUMENT_ROOT}/$2.php -f
RewriteRule ^(tr|en|ru)/([^/]+)$ $2.php?lang=$1 [L,QSA]
